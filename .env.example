# Copy to .env for local experiments only. Do not commit real secrets.

HOST=127.0.0.1
PORT=8787

# Optional: override generated Latch keys.
# OPERATOR_TOKEN=op_replace_me
# AGENT_TOKEN=agent_replace_me

# Optional: external OpenAI-compatible provider fallback.
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=replace-with-model-name
# LLM_API_KEY=replace-with-provider-key
# LLM_TIMEOUT_MS=60000

# Optional: server-side phone push.
# NOTIFY_ENABLED=false
# NOTIFY_PROVIDER=ntfy
# NOTIFY_URL=https://ntfy.sh/replace-with-private-random-topic
# NOTIFY_TOKEN=replace-with-provider-token-if-needed
# NOTIFY_TIMEOUT_MS=5000
