# Copy to /etc/latch-agent-bridge.env on the OpenClaw Ubuntu VM.
# Keep the real file readable only by root.

LATCH_BASE_URL=https://replace-with-windows-latch-tailscale-url
LATCH_AGENT_KEY=agent_replace_me
LATCH_WORKER_NAME=openclaw-vm
LATCH_POLL_INTERVAL=15
LATCH_MAX_TASKS_PER_TICK=1
LATCH_MAX_MESSAGES_PER_TICK=1
LATCH_PROCESS_EXISTING_MESSAGES=false

# Optional: set this to the OpenClaw Gateway health endpoint once confirmed.
# OPENCLAW_HEALTH_URL=http://127.0.0.1:replace-port/replace-health-path
