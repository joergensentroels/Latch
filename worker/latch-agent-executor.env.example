# Copy to /etc/latch-agent-executor.env on the OpenClaw Ubuntu VM.
# Keep the real file readable only by root.

LATCH_BASE_URL=https://replace-with-windows-latch-tailscale-url
LATCH_AGENT_KEY=agent_replace_me
LATCH_EXECUTOR_POLL_INTERVAL=10
LATCH_EXECUTOR_STATE_PATH=/var/lib/latch-agent-executor/state.json
LATCH_EXECUTOR_WORK_DIR=/var/lib/latch-agent-executor/work
LATCH_EXECUTOR_BROWSER_DIR=/var/lib/latch-agent-executor/browser
LATCH_EXECUTOR_DOWNLOAD_DIR=/var/lib/latch-agent-executor/downloads
