# Copy to a private env file on a trusted compute worker.
# Keep the real worker token readable only by the local operator.

LATCH_BASE_URL=https://replace-with-latch-tailscale-url
LATCH_WORKER_TOKEN=worker_replace_me
LATCH_WORKER_NAME=trusted-gpu-worker
LATCH_WORKER_BACKEND=ollama
LATCH_WORKER_BACKEND_URL=http://127.0.0.1:11434
LATCH_WORKER_MODELS=qwen2.5-coder:14b
LATCH_WORKER_DEFAULT_MODEL=qwen2.5-coder:14b
LATCH_WORKER_CAPACITY=1
LATCH_INPUT_CREDITS_PER_1K=1
LATCH_OUTPUT_CREDITS_PER_1K=2
LATCH_WORKER_POLL_INTERVAL=5
